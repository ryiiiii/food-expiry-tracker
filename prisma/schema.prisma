// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// 一度でも登録した食品名の履歴（削除されても残す）
model FoodName {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Food {
  id         Int       @id @default(autoincrement())
  name       String
  expiryType String    // "消費期限" | "賞味期限"
  expiryDate DateTime? // 冷凍時は不要なので nullable
  quantity   Int?      // 数量（任意）
  unit       String?   // 単位（個・本・パックなど）
  frozen     Boolean   @default(false) // 冷凍庫フラグ
  memo       String?
  notified   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}
